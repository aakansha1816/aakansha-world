---
const skills = [
  { text: 'Brand Strategy', position: 'top-[12%] left-[5%] md:left-[8%]' },
  { text: 'Digital Marketing', position: 'top-[8%] right-[5%] md:right-[10%]' },
  { text: 'Content Creation', position: 'top-[38%] left-0 md:left-[2%]' },
  { text: 'Social Media', position: 'top-[35%] right-0 md:right-[4%]' },
  { text: 'SEO & Analytics', position: 'top-[60%] left-[3%] md:left-[6%]' },
  { text: 'Campaign Management', position: 'top-[58%] right-[2%] md:right-[6%]' },
];
---

<section
  id="about"
  class="relative min-h-screen overflow-hidden bg-burgundy px-6 py-24 md:px-10 lg:px-16"
>
  <!-- Decorative skill map with silhouette -->
  <div class="relative mx-auto max-w-4xl">
    <div class="about-visual relative flex min-h-[520px] items-center justify-center md:min-h-[600px]">
      <!-- Person silhouette (inline for GSAP path animation) -->
      <svg
        id="silhouette-svg"
        class="relative z-10 h-[320px] w-auto opacity-0 md:h-[380px]"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 260 380"
        fill="none"
        stroke="#f1e4c6"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path
          class="silhouette-path"
          d="M130 45 C130 45 155 40 160 60 C165 80 160 100 150 110 C145 116 138 120 130 122 C122 120 115 116 110 110 C100 100 95 80 100 60 C105 40 130 45 130 45 Z"
        />
        <path class="silhouette-path" d="M120 122 L120 145 M140 122 L140 145" />
        <path
          class="silhouette-path"
          d="M120 145 C100 148 60 160 45 185 C35 200 30 230 30 260 L30 375 L230 375 L230 260 C230 230 225 200 215 185 C200 160 160 148 140 145"
        />
      </svg>

      <!-- Skill labels with arrows -->
      {skills.map((skill, i) => (
        <div
          class={`skill-item absolute ${skill.position} opacity-0`}
          data-index={i}
        >
          <!-- Arrow SVG -->
          <svg
            class={`arrow-svg mb-1 h-8 w-12 ${i % 2 === 0 ? 'scale-x-[-1]' : ''}`}
            viewBox="0 0 60 40"
            fill="none"
            stroke="#1a0508"
            stroke-width="2.5"
            stroke-linecap="round"
          >
            <path d="M5 30 C15 10 35 5 55 15" />
            <path d="M48 8 L55 15 L46 19" />
          </svg>
          <!-- Text block lines -->
          <div class="flex flex-col gap-1.5">
            <div class="h-[2px] w-16 rounded bg-cream/70 md:w-24"></div>
            <div class="h-[2px] w-12 rounded bg-cream/50 md:w-18"></div>
          </div>
          <span class="mt-2 block text-[10px] font-medium tracking-[0.2em] text-cream/60 uppercase md:text-xs">
            {skill.text}
          </span>
        </div>
      ))}
    </div>

    <!-- ABOUT heading -->
    <h2
      id="about-heading"
      class="mt-4 text-center font-heading text-5xl font-black tracking-tight text-cream opacity-0 md:text-7xl"
    >
      ABOUT
    </h2>

    <!-- Bio content -->
    <div id="about-bio" class="mx-auto mt-12 max-w-2xl space-y-6 text-center opacity-0">
      <p class="text-base leading-relaxed text-cream/80 md:text-lg">
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod
        tempor incididunt ut labore et dolore magna aliqua. A passionate marketing
        graduate with a keen eye for brand storytelling and data-driven strategies.
      </p>
      <p class="text-base leading-relaxed text-cream/80 md:text-lg">
        Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut
        aliquip ex ea commodo consequat. Experienced in crafting campaigns that
        resonate, building communities, and turning insights into impact.
      </p>
    </div>
  </div>
</section>
