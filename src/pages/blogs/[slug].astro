---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blogs');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout
  title={`${post.data.title} — YOUR NAME`}
  description={post.data.excerpt}
>
  <Navbar solid />

  <article class="bg-burgundy px-6 pt-32 pb-24 md:px-10 lg:px-16">
    <div class="mx-auto max-w-3xl">
      <!-- Header -->
      <header class="mb-16">
        <time class="text-xs font-medium tracking-[0.3em] text-cream/40 uppercase">
          {post.data.date}
        </time>
        <h1 class="mt-4 font-heading text-4xl font-black leading-tight tracking-tight text-cream md:text-5xl lg:text-6xl">
          {post.data.title}
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-cream/60">
          {post.data.excerpt}
        </p>
        <div class="mt-8 h-px w-16 bg-cream/20"></div>
      </header>

      <!-- Markdown body -->
      <div class="prose prose-invert max-w-none
        [&>h2]:font-heading [&>h2]:text-2xl [&>h2]:font-bold [&>h2]:tracking-tight [&>h2]:text-cream [&>h2]:mt-12 [&>h2]:mb-4 md:[&>h2]:text-3xl
        [&>h3]:font-heading [&>h3]:text-xl [&>h3]:font-bold [&>h3]:text-cream/90 [&>h3]:mt-8 [&>h3]:mb-3
        [&>p]:text-base [&>p]:leading-relaxed [&>p]:text-cream/70 [&>p]:mb-6
        [&>ul]:space-y-2 [&>ul]:mb-6 [&>ul>li]:text-cream/70 [&>ul>li]:text-base [&>ul>li]:leading-relaxed
        [&>ol]:space-y-2 [&>ol]:mb-6 [&>ol>li]:text-cream/70 [&>ol>li]:text-base [&>ol>li]:leading-relaxed
        [&_strong]:text-cream/90 [&_strong]:font-semibold
        [&_a]:text-olive [&_a]:underline [&_a]:underline-offset-2 hover:[&_a]:text-cream
        [&>blockquote]:border-l-2 [&>blockquote]:border-cream/20 [&>blockquote]:pl-6 [&>blockquote]:italic [&>blockquote]:text-cream/50
      ">
        <Content />
      </div>

      <!-- Back link -->
      <div class="mt-16 border-t border-cream/10 pt-8">
        <a
          href="/#blogs"
          class="inline-flex items-center gap-2 text-xs font-medium tracking-[0.2em] text-cream/50 uppercase transition-colors hover:text-cream"
        >
          <svg class="h-3 w-3 rotate-180" fill="none" viewBox="0 0 12 12" stroke="currentColor" stroke-width="1.5">
            <path d="M1 6h10M7 2l4 4-4 4"/>
          </svg>
          <span>Back to all posts</span>
        </a>
      </div>
    </div>
  </article>

  <!-- Footer -->
  <footer class="border-t border-cream/10 bg-burgundy px-6 py-10 md:px-10 lg:px-16">
    <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-6 md:flex-row">
      <a href="/" class="font-heading text-lg font-bold tracking-wide text-cream">AB.</a>
      <p class="text-[10px] tracking-wider text-cream/30 md:text-xs">
        &copy; {new Date().getFullYear()} YOUR NAME. All rights reserved.
      </p>
    </div>
  </footer>
</Layout>
